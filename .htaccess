ErrorDocument 404 /404.php

RewriteEngine On
RewriteCond %{HTTP_HOST} ^sorwatom\.com [NC]
RewriteCond %{SERVER_PORT} 80
RewriteRule ^(.*)$ https://www.sorwatom.com/$1 [R=301,L]
RewriteOptions inherit

# ── Security headers ────────────────────────────────────────
<IfModule mod_headers.c>
    Header always set X-Frame-Options "DENY"
    Header always set X-Content-Type-Options "nosniff"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set X-XSS-Protection "1; mode=block"
</IfModule>

# ── Block direct access to sensitive / deployment files ─────
<FilesMatch "^(about|product)-template\.php$">
    Order deny,allow
    Deny from all
</FilesMatch>
<FilesMatch "^(error_log|Dockerfile|fly\.toml|router\.php)$">
    Require all denied
</FilesMatch>

# ── Gzip / Deflate compression ──────────────────────────────
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css
    AddOutputFilterByType DEFLATE application/javascript application/json
    AddOutputFilterByType DEFLATE font/woff font/woff2
</IfModule>

# ── Serve WebP to browsers that support it ──────────────────
# slider/ and products/ images all have .webp counterparts.
AddType image/webp .webp
<IfModule mod_rewrite.c>
  RewriteCond %{HTTP_ACCEPT} image/webp
  RewriteRule ^(assets/img/(?:slider|products)/[^/]+)\.(jpe?g|png)$ /$1.webp [T=image/webp,L,NC]
</IfModule>
<IfModule mod_headers.c>
  <FilesMatch "\.(jpe?g|png)$">
    Header append Vary Accept
  </FilesMatch>
</IfModule>

# ── Browser caching for static assets ───────────────────────
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType text/css                  "access plus 1 month"
    ExpiresByType application/javascript    "access plus 1 month"
    ExpiresByType image/png                 "access plus 6 months"
    ExpiresByType image/jpeg                "access plus 6 months"
    ExpiresByType image/webp                "access plus 6 months"
    ExpiresByType image/svg+xml             "access plus 6 months"
    ExpiresByType font/woff                 "access plus 1 year"
    ExpiresByType font/woff2                "access plus 1 year"
</IfModule>

# ── Clean URL routing ──────────────────────────────────────
# Redirect /page.php → /page (removes .php from browser bar)
RewriteCond %{THE_REQUEST} \s/+(.+?)\.php[\s?] [NC]
RewriteRule ^ /%1 [R=301,L,NE]

# RSS feed: /feed → feed.php
RewriteRule ^feed/?$ feed.php [L]

# Blog post: /blog/slug → blog-post.php?slug=slug
RewriteRule ^blog/([a-zA-Z0-9_-]+)/?$ blog-post.php?slug=$1 [L,QSA]

# Serve /page as page.php if the file exists
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME}.php -f
RewriteRule ^([^.]+)$ $1.php [L]

# If no file or .php match found — serve 404 page
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^ /404.php [L]
